  "typography": {
    "serif": "\"Cormorant Garamond\", Georgia, serif",
    "sans": "\"DM Sans\", sans-serif",
    "display": {
      "fontFamily": "serif",
      "fontWeight": 300,
      "lineHeight": 0.98,
      "letterSpacing": "-0.01em"
    },
    "body": {
      "fontFamily": "sans",
      "fontWeight": 400,
      "lineHeight": 1.4
    },
    "label": {
      "fontFamily": "sans",
      "fontWeight": 400,
      "letterSpacing": "0.18em",
      "textTransform": "uppercase"
    },
    "numeric": {
      "fontFamily": "serif",
      "fontWeight": 300,
      "fontVariantNumeric": "tabular-nums"
    }
  },
  "radius": {
    "none": "0",
    "xs": "4px",
    "sm": "8px",
    "control": "10px",
    "md": "12px",
    "sheet": "16px",
    "lg": "18px",
    "pill": "999px"
  },
  "spacing": {
    "unit": 4,
    "appGutter": "14px",
    "space2xs": "4px",
    "spaceXs": "8px",
    "spaceSm": "12px",
    "spaceMd": "16px",
    "spaceLg": "24px",
    "spaceXl": "32px",
    "screenPaddingMobile": "14px",
    "screenPaddingTablet": "40px",
    "screenPaddingDesktop": "40px"
  },
  "border": {
    "width": "1px",
    "style": "solid",
    "emphasis": "thin editorial rules before heavy card chrome"
  },
  "shadow": {
    "soft": "0 18px 44px rgba(0, 0, 0, 0.22)",
    "innerGlow": "inset 0 1px 0 rgba(240, 239, 235, 0.05)",
    "sheet": "0 -16px 42px rgba(0, 0, 0, 0.38)"
  },
  "motion": {
    "durationFast": "180ms",
    "durationBase": "180ms",
    "durationReveal": "220ms",
    "easeOutQuart": "cubic-bezier(0.22, 1, 0.36, 1)",
    "reveal": {
      "from": { "opacity": 0, "translateY": "8px" },
      "to": { "opacity": 1, "translateY": "0" }
    }
  },
  "breakpoints": {
    "compact": "360px",
    "mobileWide": "430px",
    "singleColumn": "560px",
    "mobileNav": "900px",
    "desktop": "1024px"
  },
  "componentDefaults": {
    "button": {
      "heightMobile": "48px",
      "heightDesktop": "52px",
      "radius": "10px",
      "letterSpacing": "0.1em",
      "textTransform": "uppercase"
    },
    "input": {
      "heightMobile": "48px",
      "radius": "10px",
      "labelPosition": "above",
      "helperText": true
    },
    "card": {
      "radius": "12px",
      "border": "thin",
      "shadow": "minimal",
      "avoidNestedCards": true
    },
    "bottomActionBar": {
      "mobileOnly": true,
      "background": "surfaceStrong",
      "safeAreaAware": true
    }
  }
