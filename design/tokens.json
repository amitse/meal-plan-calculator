{
  "$schema": "https://example.local/meal-plan-calculator/design-tokens.schema.json",
  "name": "meal-plan-calculator-pehle-warm-modern",
  "source": {
    "brand": "Pehle Health",
    "url": "https://pehlehealth.com/",
    "notes": "Tokens are adapted from the public Pehle Health CSS: dark-first editorial wellness, Cormorant Garamond + DM Sans, warm off-white ink, charcoal surfaces, thin borders, restrained uppercase labels."
  },
  "style": {
    "tastePackStyle": "warm-modern",
    "supportingMood": "soft",
    "designVariance": 5,
    "motionIntensity": 4,
    "visualDensity": 4,
    "mobileFirst": true
  },
  "color": {
    "dark": {
      "bg": "#141414",
      "bgAlt": "#1c1c1c",
      "ink": "#F0EFEB",
      "inverseInk": "#0D0D0D",
      "body": "#909090",
      "mid": "#707070",
      "muted": "#585858",
      "faint": "#383838",
      "border": "#2e2e2e",
      "borderLight": "#252525",
      "deepPanel": "#0e0e0e",
      "navBg": "rgba(20, 20, 20, 0.92)",
      "focus": "#F0EFEB",
      "success": "#7FA177",
      "warning": "#C9A24A",
      "danger": "#C66A5B"
    },
    "light": {
      "bg": "#F7F6F2",
      "bgAlt": "#EFEDE8",
      "ink": "#141414",
      "inverseInk": "#F4F3F0",
      "body": "#2A2A2A",
      "mid": "#4A4A4A",
      "muted": "#6B6B6B",
      "faint": "#999999",
      "border": "#DDDBD6",
      "borderLight": "#E8E6E1",
      "deepPanel": "#111111",
      "navBg": "rgba(247, 246, 242, 0.94)",
      "focus": "#0D0D0D",
      "success": "#4F7F56",
      "warning": "#A97C28",
      "danger": "#A44A3F"
    }
  },
  "typography": {
    "serif": "\"Cormorant Garamond\", Georgia, serif",
    "sans": "\"DM Sans\", sans-serif",
    "display": {
      "fontFamily": "serif",
      "fontWeight": 300,
      "lineHeight": 0.98,
      "letterSpacing": "-0.01em"
    },
    "body": {
      "fontFamily": "sans",
      "fontWeight": 300,
      "lineHeight": 1.75
    },
    "label": {
      "fontFamily": "sans",
      "fontWeight": 400,
      "letterSpacing": "0.18em",
      "textTransform": "uppercase"
    },
    "numeric": {
      "fontFamily": "serif",
      "fontWeight": 300,
      "fontVariantNumeric": "tabular-nums"
    }
  },
  "radius": {
    "none": "0",
    "xs": "4px",
    "sm": "8px",
    "md": "12px",
    "lg": "18px",
    "pill": "999px"
  },
  "spacing": {
    "unit": 4,
    "screenPaddingMobile": "24px",
    "screenPaddingTablet": "32px",
    "screenPaddingDesktop": "48px",
    "sectionMobile": "72px",
    "sectionDesktop": "120px"
  },
  "border": {
    "width": "1px",
    "style": "solid",
    "emphasis": "thin editorial rules before heavy card chrome"
  },
  "shadow": {
    "card": "0 18px 44px rgba(0, 0, 0, 0.18)",
    "lift": "0 14px 32px rgba(0, 0, 0, 0.16)"
  },
  "motion": {
    "durationFast": "160ms",
    "durationBase": "240ms",
    "durationReveal": "700ms",
    "ease": "cubic-bezier(0.22, 1, 0.36, 1)",
    "reveal": {
      "from": { "opacity": 0, "translateY": "20px" },
      "to": { "opacity": 1, "translateY": "0" }
    }
  },
  "breakpoints": {
    "compact": "360px",
    "mobileWide": "430px",
    "singleColumn": "560px",
    "mobileNav": "900px",
    "desktop": "1024px"
  },
  "componentDefaults": {
    "button": {
      "heightMobile": "48px",
      "heightDesktop": "52px",
      "radius": "0",
      "letterSpacing": "0.1em",
      "textTransform": "uppercase"
    },
    "input": {
      "heightMobile": "52px",
      "radius": "8px",
      "labelPosition": "above",
      "helperText": true
    },
    "card": {
      "radius": "12px",
      "border": "thin",
      "shadow": "minimal",
      "avoidNestedCards": true
    },
    "bottomActionBar": {
      "mobileOnly": true,
      "height": "72px",
      "background": "navBg",
      "backdropBlur": "14px"
    }
  }
}
