{
  "name": "meal-plan-calculator",
  "version": "1.0.0",
  "description": "Schema-defined nutrition planning MasterData and read API.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "data",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:www": "vite build --config site/vite.config.ts",
    "dev:www": "vite --config site/vite.config.ts",
    "preview:www": "vite preview --config site/vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "nutrition",
    "meal-planning"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "ajv": "^8.20.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
