{
  "name": "meal-plan-calculator",
  "version": "1.0.0",
  "description": "Schema-defined nutrition planning MasterData and read API.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "data",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:www": "vite build --config site/vite.config.ts",
    "dev:www": "vite --config site/vite.config.ts",
    "preview:www": "vite preview --config site/vite.config.ts",
    "ux:issue:generate-loop": "node scripts/copilot-issue-loop.mjs generate-loop",
    "ux:issue:fix-loop": "node scripts/copilot-issue-loop.mjs fix-loop",
    "ux:issue:fix-next": "node scripts/copilot-issue-loop.mjs fix-next",
    "ux:issue:generate": "node scripts/copilot-issue-loop.mjs generate",
    "ux:issue:run-hour": "node scripts/copilot-issue-loop.mjs run-hour",
    "ux:issue:status": "node scripts/copilot-issue-loop.mjs status",
    "ux:copilot-pipeline": "node scripts/copilot-ux-pipeline.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "nutrition",
    "meal-planning"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "ajv": "^8.20.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
